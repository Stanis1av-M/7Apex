<!DOCTYPE html>
<html lang="ru" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 7apex TOURS</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="d-flex flex-column h-100 bg-white">

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-black fixed-top py-3 shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold text-uppercase letter-spacing-2"
                   asp-controller="Home" asp-action="Index">
                    7apex <span class="fw-light text-muted">Tours</span>
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav align-items-center">

                        <li class="nav-item">
                            <a class="nav-link text-uppercase fw-bold px-3 small"
                               asp-controller="Tours" asp-action="Index">Маршруты</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-uppercase fw-bold px-3 small"
                               asp-controller="Shop" asp-action="Index">Магазин</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-uppercase fw-bold px-3 small"
                               asp-controller="Home" asp-action="About">О нас</a>
                        </li>

                        <!-- НОВЫЙ ПУНКТ -->
                        <li class="nav-item">
                            <a class="nav-link text-uppercase fw-bold px-3 small"
                               asp-controller="Feedback" asp-action="Create">
                                Связаться с нами
                            </a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item ms-lg-3">
                                <a class="nav-link text-white px-2"
                                   title="Избранное"
                                   asp-controller="Favorites" asp-action="Index">
                                    <i class="bi bi-heart"></i>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white px-2"
                                   title="Корзина"
                                   asp-controller="Cart" asp-action="Index">
                                    <i class="bi bi-cart3"></i>
                                </a>
                            </li>

                            <li class="nav-item dropdown ms-lg-2">
                                <a class="nav-link dropdown-toggle text-white text-uppercase fw-bold small border border-secondary px-3"
                                   href="#" id="userMenu"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    <i class="bi bi-person-circle me-1"></i> @User.Identity.Name
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end bg-black border-secondary shadow-lg mt-2">
                                    <li>
                                        <a class="dropdown-item text-white small text-uppercase fw-bold ls-1 py-2"
                                           asp-controller="Profile" asp-action="Index">
                                            Профиль
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item text-white small text-uppercase fw-bold ls-1 py-2"
                                           asp-controller="Cart" asp-action="Index">
                                            Мои заказы
                                        </a>
                                    </li>

                                    @if (User.IsInRole("Администратор") || User.IsInRole("Менеджер"))
                                    {
                                        <li><hr class="dropdown-divider bg-secondary"></li>
                                        <li class="px-3 py-1 small text-muted text-uppercase fw-bold" style="font-size: 0.6rem;">
                                            Управление
                                        </li>
                                        <li>
                                            <a class="dropdown-item text-warning small text-uppercase fw-bold ls-1 py-2"
                                               asp-controller="Admin" asp-action="Index">
                                                Панель управления
                                            </a>
                                        </li>
                                    }

                                    <li><hr class="dropdown-divider bg-secondary"></li>

                                    <li>
                                        <a class="dropdown-item text-danger small text-uppercase fw-bold ls-1 py-2"
                                           asp-controller="Account" asp-action="Logout">
                                            Выход
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-lg-4">
                                <a class="btn btn-outline-light btn-sm text-uppercase px-4 py-2"
                                   style="font-size: 0.7rem; border-radius: 0;"
                                   asp-controller="Account" asp-action="Login">
                                    Войти
                                </a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-shrink-0 flex-grow-1" style="padding-top: 80px;">
        @RenderBody()
    </main>

    <footer class="footer mt-auto bg-black text-white pt-5 pb-4 position-relative overflow-hidden">
        <div class="mountain-decor"></div>

        <div class="container position-relative" style="z-index: 2;">
            <div class="row">

                <div class="col-md-4 mb-4">
                    <h5 class="text-uppercase fw-bold mb-4 ls-1">7apex</h5>
                    <p class="text-muted small" style="max-width: 300px;">
                        Мы организуем экспедиции в самые отдаленные уголки планеты.
                    </p>
                </div>

                <div class="col-md-4 mb-4 text-center">
                    <h5 class="text-uppercase fw-bold mb-4 ls-1">Контакты</h5>
                    <p class="text-muted small mb-1">+7 (999) 000-00-00</p>
                    <p class="text-muted small">adventure@7apex.ru</p>
                </div>

                <div class="col-md-4 mb-4 text-end">
                    <h5 class="text-uppercase fw-bold mb-4 ls-1">Следите за нами</h5>
                    <div class="d-flex justify-content-end gap-3 fs-5">
                        <i class="bi bi-instagram"></i>
                        <i class="bi bi-telegram"></i>
                        <i class="bi bi-youtube"></i>
                    </div>
                </div>

            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

</body>
</html>