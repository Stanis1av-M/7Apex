@model Apex7.Data.Entities.Product

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-11">

            <!-- Шапка -->
            <div class="mb-4">
                <a asp-action="Index" class="text-decoration-none text-muted small fw-bold text-uppercase ls-1">
                    <i class="bi bi-arrow-left me-1"></i> Назад к списку
                </a>
                <h2 class="text-uppercase fw-black mb-0 mt-2 ls-1" style="font-size: 1.8rem;">
                    <span class="text-success">Новый</span> Товар
                </h2>
            </div>

            <!-- Форма создания -->
            <form asp-action="Create" method="post" enctype="multipart/form-data" class="bg-white p-4 p-md-5 shadow-sm rounded-4 border">

                <!-- Сводка глобальных ошибок -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger border-0 shadow-sm rounded-3 mb-4">
                        <i class="bi bi-exclamation-circle-fill me-2"></i> Проверьте правильность заполнения всех полей.
                    </div>
                }

                <!-- СЕКЦИЯ 1: Основная информация -->
                <div class="row g-4 mb-5">
                    <div class="col-12 border-bottom pb-2">
                        <h5 class="text-uppercase fw-bold mb-0 small text-muted ls-2"><i class="bi bi-info-circle me-2"></i>Основная информация</h5>
                    </div>
                    <div class="col-md-7">
                        <label class="form-label small fw-bold text-uppercase text-muted">Название товара <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control form-control-lg bg-light border-0 shadow-none" placeholder="Напр: Палатка горная" required />
                        <span asp-validation-for="Name" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label small fw-bold text-uppercase text-muted">Артикул <span class="text-danger">*</span></label>
                        <input asp-for="Article" class="form-control form-control-lg bg-light border-0 shadow-none" placeholder="ABC-123" required />
                        <span asp-validation-for="Article" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                </div>

                <!-- СЕКЦИЯ 2: Классификация -->
                <div class="row g-4 mb-5">
                    <div class="col-12 border-bottom pb-2">
                        <h5 class="text-uppercase fw-bold mb-0 small text-muted ls-2"><i class="bi bi-tags me-2"></i>Классификация</h5>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-uppercase text-muted">Категория *</label>
                        <select asp-for="CategoryId" class="form-select form-select-lg bg-light border-0 shadow-none fw-bold" asp-items="ViewBag.Categories" required>
                            <option value="">-- Выберите --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-uppercase text-muted">Производитель *</label>
                        <select asp-for="ManufacturerId" class="form-select form-select-lg bg-light border-0 shadow-none fw-bold" asp-items="ViewBag.Manufacturers" required>
                            <option value="">-- Выберите --</option>
                        </select>
                        <span asp-validation-for="ManufacturerId" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-uppercase text-muted">Поставщик *</label>
                        <select asp-for="SupplierId" class="form-select form-select-lg bg-light border-0 shadow-none fw-bold" asp-items="ViewBag.Suppliers" required>
                            <option value="">-- Выберите --</option>
                        </select>
                        <span asp-validation-for="SupplierId" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                </div>

                <!-- СЕКЦИЯ 3: Коммерческие данные -->
                <div class="row g-4 mb-5 p-4 rounded-4 bg-light border-0">
                    <div class="col-12 mb-2">
                        <h5 class="text-uppercase fw-bold mb-0 small text-dark ls-2"><i class="bi bi-cash-stack me-2"></i>Цены и Склад</h5>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-uppercase">Цена (₽) *</label>
                        <input asp-for="Price" type="number" step="0.01" min="0" max="1000000" class="form-control form-control-lg bg-white border-0 shadow-sm fw-bold text-primary" required />
                        <span asp-validation-for="Price" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-uppercase">Старая цена</label>
                        <input asp-for="OldPrice" type="number" step="0.01" min="0" max="1000000" class="form-control form-control-lg bg-white border-0 shadow-sm text-muted" />
                        <span asp-validation-for="OldPrice" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-uppercase text-danger">Остаток (макс 99) *</label>
                        <input asp-for="Stock" type="number" min="0" max="99" class="form-control form-control-lg bg-white border-0 shadow-sm fw-bold text-danger" required />
                        <span asp-validation-for="Stock" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check form-switch mb-2 ms-2">
                            <input asp-for="IsVisible" class="form-check-input custom-switch" type="checkbox" id="vCheck" checked role="switch">
                            <label class="form-check-label small fw-bold text-uppercase ms-2" for="vCheck" style="cursor: pointer;">В продаже</label>
                        </div>
                    </div>
                </div>

                <!-- СЕКЦИЯ 4: Описание и Фото -->
                <div class="row g-4 mb-5">
                    <div class="col-md-8">
                        <label class="form-label small fw-bold text-uppercase text-muted">Описание (макс. 250 символов)</label>
                        <textarea asp-for="Description" id="descText" class="form-control bg-light border-0 shadow-none p-3" rows="5" maxlength="250" placeholder="Краткое описание товара..."></textarea>
                        <div class="text-end mt-1"><small id="charCount" class="text-muted">0 / 250</small></div>
                        <span asp-validation-for="Description" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-uppercase text-muted">Фотография</label>
                        <div class="p-3 bg-light rounded-4 border-dashed text-center h-100 d-flex flex-column align-items-center justify-content-center">
                            <i class="bi bi-image text-muted fs-1 mb-2"></i>
                            <input type="file" name="imageFile" class="form-control form-control-sm bg-white border-0" accept="image/*" />
                        </div>
                    </div>
                </div>

                <div class="text-center pt-4 border-top">
                    <button type="submit" class="btn btn-dark btn-lg px-5 py-3 text-uppercase fw-bold ls-2 rounded-pill shadow-lg hover-scale">
                        Создать и опубликовать
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Блокировка нежелательных клавиш в числовых полях
        document.querySelectorAll('input[type="number"]').forEach(input => {
            input.addEventListener('keydown', function(e) {
                if (['e', 'E', '-', '+'].includes(e.key)) e.preventDefault();
            });
        });

        // Счетчик символов для описания
        const textarea = document.getElementById('descText');
        const charCount = document.getElementById('charCount');

        textarea.addEventListener('input', () => {
            const length = textarea.value.length;
            charCount.textContent = `${length} / 250`;
            charCount.className = length >= 240 ? 'text-danger fw-bold' : 'text-muted';
        });
    </script>
}

<style>
    .ls-2 {
        letter-spacing: 2px;
    }

    .fw-black {
        font-weight: 900;
    }

    .border-dashed {
        border: 2px dashed #dee2e6;
    }

    .custom-switch {
        width: 3rem !important;
        height: 1.5rem !important;
        cursor: pointer;
    }

    .hover-scale {
        transition: transform 0.2s;
    }

        .hover-scale:hover {
            transform: scale(1.02);
        }

    .form-control-lg, .form-select-lg {
        font-size: 0.95rem;
        border-radius: 12px;
    }
</style>