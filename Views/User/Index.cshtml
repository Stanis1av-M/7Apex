@model Apex7.Data.Entities.User

@{
    ViewData["Title"] = "Мой профиль";
}

<div class="container py-5 mt-4">
    <h2 class="fw-800 text-uppercase mb-4">Мой <span class="text-primary">Профиль</span></h2>

    @* Блок для вывода сообщения об успешном обновлении профиля *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4 border-0 shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="row">
        <div class="col-md-5 col-lg-4 mb-4">
            <div class="card border-0 shadow-sm rounded-4 text-center p-4">
                <div class="bg-light rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                    <i class="bi bi-person-fill text-secondary" style="font-size: 3rem;"></i>
                </div>
                <h4 class="fw-bold mb-1">@Model.FullName</h4>
                <p class="text-muted small mb-3">@Model.Role?.Name</p>
                <hr class="bg-secondary opacity-25">

                <div class="text-start mt-3">
                    <p class="mb-2"><i class="bi bi-envelope text-primary me-2"></i> <strong>Email:</strong> <br> <span class="text-muted">@Model.Email</span></p>
                    <p class="mb-0"><i class="bi bi-calendar3 text-primary me-2"></i> <strong>На сайте с:</strong> <br> <span class="text-muted">@Model.RegistrationDate.ToString("dd.MM.yyyy")</span></p>
                </div>

                @* ДОБАВЛЕНА КНОПКА РЕДАКТИРОВАНИЯ *@
                <div class="mt-4 pt-3 border-top border-light text-center">
                    <a asp-action="EditProfile" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-bold shadow-sm w-100 hover-lift">
                        <i class="bi bi-pencil-square me-2"></i> Редактировать
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-7 col-lg-8">
            <div class="row g-3">
                <div class="col-sm-6">
                    <a asp-action="MyOrders" class="text-decoration-none">
                        <div class="card border-0 shadow-sm rounded-4 p-4 hover-lift h-100">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary-subtle text-primary rounded-3 p-3 me-3">
                                    <i class="bi bi-bag-check fs-3"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold text-dark mb-0">Мои заказы</h5>
                                    <span class="small text-muted">История покупок</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-sm-6">
                    <a asp-action="MyRequests" class="text-decoration-none">
                        <div class="card border-0 shadow-sm rounded-4 p-4 hover-lift h-100">
                            <div class="d-flex align-items-center">
                                <div class="bg-warning-subtle text-warning rounded-3 p-3 me-3">
                                    <i class="bi bi-envelope-paper fs-3"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold text-dark mb-0">Мои обращения</h5>
                                    <span class="small text-muted">Связь с поддержкой</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 {
        font-weight: 800;
    }

    .hover-lift {
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .hover-lift:hover {
            transform: translateY(-3px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.1) !important;
        }

    .bg-primary-subtle {
        background-color: #cce5ff;
    }

    .bg-warning-subtle {
        background-color: #fff3cd;
    }
</style>