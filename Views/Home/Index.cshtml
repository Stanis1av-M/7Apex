@model IEnumerable<Apex7.Data.Entities.News>

<!-- 1. Hero Section -->
<section class="hero-section mb-5">
    <div>
        <h1 class="display-1 fw-bold text-uppercase">7apex Tours</h1>
        <p class="fs-4 text-uppercase letter-spacing-2">Экспедиции, в которых рождаются легенды</p>

        <!-- ИСПРАВЛЕНО: Теперь ведет на контроллер Tours, метод Index -->
        <a asp-controller="Tours" asp-action="Index"
           class="btn btn-light btn-lg mt-4 px-5 py-3 text-uppercase fw-bold"
           style="border-radius:0;">Наши маршруты</a>
    </div>
</section>

<div class="container section-padding" id="expeditions">
    <div class="mb-5">
        <h6 class="text-uppercase text-muted mb-2">Наш путь</h6>
        <h2 class="display-5 fw-bold text-uppercase">Последние экспедиции</h2>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 bg-white shadow-sm border-0">
                    <div class="position-absolute top-0 start-0 bg-white text-dark px-3 py-1 m-3 small fw-bold shadow-sm" style="z-index: 2;">
                        @item.CreatedAt.ToString("dd.MM.yyyy")
                    </div>

                    <img src="@(item.ImageURL ?? "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=800&q=80")"
                         class="card-img-top" alt="@item.Title" style="height: 400px; object-fit: cover;">

                    <div class="card-body p-4">
                        <h5 class="fw-bold text-uppercase mb-3" style="line-height: 1.2; height: 2.4em; overflow: hidden;">
                            @item.Title
                        </h5>
                        <p class="text-muted small mb-0" style="height: 4.8em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; line-height: 1.6;">
                            @item.Content
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Блок преимуществ остается без изменений -->
<section class="py-5 mt-5 bg-light">
    <div class="container text-center py-5">
        <h6 class="text-uppercase text-muted mb-3 small fw-bold">Почему выбирают нас</h6>
        <div class="row mt-5 g-4">
            <div class="col-md-4">
                <div class="p-3">
                    <i class="bi bi-shield-check fs-1 mb-3 text-dark"></i>
                    <h6 class="fw-bold text-uppercase mb-3">Безопасность</h6>
                    <p class="small text-muted">Сертифицированное снаряжение и гиды с опытом восхождений более 10 лет.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3">
                    <i class="bi bi-geo-alt fs-1 mb-3 text-dark"></i>
                    <h6 class="fw-bold text-uppercase mb-3">Локации</h6>
                    <p class="small text-muted">Уникальные маршруты: от Гималайских восьмитысячников до диких троп Алтая.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3">
                    <i class="bi bi-people fs-1 mb-3 text-dark"></i>
                    <h6 class="fw-bold text-uppercase mb-3">Сообщество</h6>
                    <p class="small text-muted">Мы объединяем людей, для которых горы — это не просто отдых, а стиль жизни.</p>
                </div>
            </div>
        </div>
    </div>
</section>