@model IEnumerable<Apex7.Data.Entities.News>

@{
    ViewData["Title"] = "Главная";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Inter', sans-serif;
        background-color: #fff;
    }

    .fw-800 {
        font-weight: 800;
    }

    /* Hero Section */
    .hero-section {
        height: 80vh;
        background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1920&q=80');
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: white;
    }

    .letter-spacing-2 {
        letter-spacing: 2px;
    }

    /* Cards */
    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .hover-lift:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
        }

    .date-badge {
        position: absolute;
        top: 20px;
        left: 20px;
        background: white;
        padding: 8px 15px;
        border-radius: 4px;
        font-weight: 700;
        font-size: 0.8rem;
        z-index: 10;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .card-title {
        height: 3rem;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        transition: color 0.3s;
    }

    .hover-lift:hover .card-title {
        color: #0d6efd;
    }
</style>

<section class="hero-section">
    <div class="container">
        <h1 class="display-1 fw-800 text-uppercase mb-3 tracking-tighter">7apex Tours</h1>
        <p class="fs-4 text-uppercase letter-spacing-2 fw-light opacity-75">Экспедиции, в которых рождаются легенды</p>
        <a asp-controller="Tours" asp-action="Index"
           class="btn btn-light btn-lg mt-4 px-5 py-3 text-uppercase fw-bold shadow-lg"
           style="border-radius:0; letter-spacing: 1px;">Наши маршруты</a>
    </div>
</section>

<div class="container py-5 my-5" id="expeditions">
    <div class="row align-items-end mb-5">
        <div class="col-md-8">
            <h6 class="text-uppercase text-primary fw-bold mb-2 small">Наш путь</h6>
            <h2 class="display-5 fw-800 text-uppercase m-0" style="letter-spacing: -1px;">Последние экспедиции</h2>
        </div>
        <div class="col-md-4 text-md-end d-none d-md-block">
            <a href="#" class="text-dark fw-bold text-decoration-none border-bottom border-2 border-primary pb-1">Все новости →</a>
        </div>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden hover-lift bg-white">
                        <div class="position-relative">
                            <div class="date-badge text-uppercase">
                                @item.CreatedAt.ToString("dd.MM.yyyy")
                            </div>
                            <img src="@(item.ImageURL ?? "/images/default-expedition.jpg")"
                                 class="card-img-top" alt="@item.Title"
                                 style="height: 300px; object-fit: cover;">
                        </div>

                        <div class="card-body p-4">
                            <h5 class="fw-bold text-uppercase card-title mb-3">
                                @item.Title
                            </h5>
                            <p class="text-muted small mb-0" style="height: 4.8em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; line-height: 1.6;">
                                @item.Content
                            </p>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted italic">Новых экспедиций пока не опубликовано. Мы готовимся к походу!</p>
            </div>
        }
    </div>
</div>

<section class="py-5 bg-light">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h6 class="text-uppercase text-primary fw-bold mb-3 small">Почему выбирают нас</h6>
            <h2 class="fw-800 text-uppercase">Профессионализм в деталях</h2>
        </div>

        <div class="row g-4 mt-2">
            <div class="col-md-4">
                <div class="card border-0 bg-transparent h-100 text-center">
                    <div class="mb-4">
                        <i class="bi bi-shield-check fs-1 text-primary"></i>
                    </div>
                    <h6 class="fw-bold text-uppercase mb-3">Безопасность</h6>
                    <p class="small text-muted px-lg-4">Сертифицированное снаряжение и гиды с опытом восхождений более 10 лет.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 bg-transparent h-100 text-center">
                    <div class="mb-4">
                        <i class="bi bi-geo-alt fs-1 text-primary"></i>
                    </div>
                    <h6 class="fw-bold text-uppercase mb-3">Локации</h6>
                    <p class="small text-muted px-lg-4">Уникальные маршруты: от Гималайских восьмитысячников до диких троп Алтая.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 bg-transparent h-100 text-center">
                    <div class="mb-4">
                        <i class="bi bi-people fs-1 text-primary"></i>
                    </div>
                    <h6 class="fw-bold text-uppercase mb-3">Сообщество</h6>
                    <p class="small text-muted px-lg-4">Мы объединяем людей, для которых горы — это не просто отдых, а стиль жизни.</p>
                </div>
            </div>
        </div>
    </div>
</section>