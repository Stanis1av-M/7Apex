@{
    ViewData["Title"] = "Детали экспедиции";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            @* Верхняя навигация (хлебные крошки) в стиле админки *@
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Tours" asp-action="Index" class="text-decoration-none text-muted small">Маршруты</a></li>
                    <li class="breadcrumb-item active small" aria-current="page">Подробности</li>
                </ol>
            </nav>

            @* Основная карточка с информацией *@
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 p-md-5 text-center">

                    @* Иконка в круге, как в личном кабинете *@
                    <div class="bg-primary-subtle text-primary rounded-circle mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                        <i class="bi bi-telephone-plus fs-1"></i>
                    </div>

                    <h1 class="fw-800 text-uppercase mb-3 tracking-tight" style="letter-spacing: -1px;">
                        Узнать <span class="text-primary">подробности</span>
                    </h1>

                    <p class="text-muted mb-5">
                        Наши экспедиции требуют индивидуального подхода. Позвоните нам, чтобы обсудить детали маршрута, уровень сложности и необходимое снаряжение.
                    </p>

                    @* Блок с номером телефона *@
                    <div class="bg-light rounded-4 p-4 mb-5 border-start border-4 border-primary">
                        <span class="small text-uppercase fw-bold text-muted ls-1 d-block mb-2">Прямая линия с организатором</span>
                        <a href="tel:+79990000000" class="display-5 fw-bold text-dark text-decoration-none hover-primary transition-3">
                            +7 (999) 000-00-00
                        </a>
                        <div class="small text-muted mt-2">Ежедневно с 09:00 до 21:00 по МСК</div>
                    </div>

                    @* Кнопки действий *@
                    <div class="d-grid gap-3">
                        <a href="javascript:history.back()" class="btn btn-dark rounded-pill py-3 fw-bold text-uppercase ls-1 hover-lift">
                            <i class="bi bi-arrow-left me-2"></i> Вернуться к турам
                        </a>
                        <a asp-controller="User" asp-action="Contact" class="btn btn-link text-muted small text-decoration-none">
                            Или напишите нам через форму связи
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Подключаем общие стили для консистентности */
    .fw-800 {
        font-weight: 800;
    }

    .ls-1 {
        letter-spacing: 1px;
    }

    .bg-primary-subtle {
        background-color: #e7f0ff;
    }

    .transition-3 {
        transition: 0.3s;
    }

    .hover-primary:hover {
        color: #0d6efd !important;
    }

    .hover-lift {
        transition: transform 0.2s;
    }

        .hover-lift:hover {
            transform: translateY(-3px);
        }

    /* Адаптация заголовка под мобильные устройства */
    @@media (max-width: 576px) {
        .display-5 {
            font-size: 1.8rem;
        }
    }
</style>