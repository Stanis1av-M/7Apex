@model IEnumerable<Apex7.Data.Entities.Feedback>
@using Apex7.Data.Entities

@{
    ViewData["Title"] = "Управление обращениями";
}

<div class="container py-5 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-2">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Админ-панель</a></li>
                    <li class="breadcrumb-item active small" aria-current="page">Обращения</li>
                </ol>
            </nav>
            <h2 class="fw-800 text-uppercase m-0">Все <span class="text-purple">Обращения</span></h2>
        </div>
        <span class="badge bg-light text-dark border rounded-pill px-3 py-2">Всего: @Model.Count()</span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4 border-0 shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5 bg-white rounded-4 shadow-sm border">
                <i class="bi bi-inbox fs-1 text-muted opacity-25"></i>
                <h4 class="mt-3 fw-bold">Нет новых обращений</h4>
                <p class="text-muted">Как только пользователи напишут, их сообщения появятся здесь.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-12 mb-4">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

                        @* Шапка карточки *@
                        <div class="card-header bg-light border-0 pt-4 px-4 d-flex justify-content-between align-items-start">
                            <div>
                                <div class="small fw-bold text-dark mb-1">
                                    Заявка #@item.FeedbackID
                                    <span class="text-muted ms-2 fw-normal"><i class="bi bi-clock"></i> @item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                                </div>
                                <h6 class="mb-0 fw-bold">@item.Name <span class="text-muted fw-normal small">(Email: @item.Email)</span></h6>
                            </div>

                            @* Текущий статус *@
                            <div>
                                @switch (item.Status)
                                {
                                    case FeedbackStatus.Pending:
                                        <span class="badge bg-warning text-dark rounded-pill px-3 py-2">В ожидании</span>
                                        break;
                                    case FeedbackStatus.Accepted:
                                        <span class="badge bg-success text-white rounded-pill px-3 py-2">Решено</span>
                                        break;
                                    case FeedbackStatus.Rejected:
                                        <span class="badge bg-danger text-white rounded-pill px-3 py-2">Отклонено</span>
                                        break;
                                }
                            </div>
                        </div>

                        <div class="card-body px-4 py-4">
                            @* Вопрос пользователя *@
                            <div class="bg-white border p-3 rounded-3 mb-4 border-start border-4" style="border-left-color: #8b5cf6 !important;">
                                <span class="small text-muted text-uppercase fw-bold ls-1 d-block mb-2">Сообщение:</span>
                                <p class="mb-0 text-dark">@item.Message</p>
                            </div>

                            <form asp-action="ReviewFeedback" method="post" class="bg-light p-4 rounded-4">
                                <input type="hidden" name="id" value="@item.FeedbackID" />

                                <div class="mb-3">
                                    <label class="small fw-bold text-uppercase ls-1 mb-2">Ответ администратора</label>

                                    @* ИСПРАВЛЕНИЕ: Добавлен maxlength и атрибуты валидации вместо жесткого required *@
                                    <textarea name="adminResponse"
                                      class="form-control rounded-3 border-secondary-subtle"
                                      rows="3"
                                      maxlength="300"
                                      placeholder="Напишите ответ пользователю (макс. 300 символов)..."
                                      @(!User.IsInRole("Администратор") ? "readonly" : "")
                                      data-val="true"
                                      data-val-required="Пожалуйста, напишите текст ответа."
                                      data-val-length="Ответ не может превышать 300 символов."
                                      data-val-length-max="300">@item.AdminResponse</textarea>

                                    @* Контейнер для вывода красивой красной ошибки *@
                                    <span class="text-danger small fw-bold field-validation-valid mt-1 d-block" data-valmsg-for="adminResponse" data-valmsg-replace="true"></span>
                                </div>

                                <div class="row align-items-center">
                                    <div class="col-md-4 mb-3 mb-md-0">
                                        <label class="small fw-bold text-uppercase ls-1 mb-2">Изменить статус</label>
                                        <select name="status" class="form-select rounded-3 border-secondary-subtle" @(!User.IsInRole("Администратор") ? "disabled" : "")>
                                            <option value="Pending" selected="@(item.Status == FeedbackStatus.Pending ? "selected" : null)">В ожидании</option>
                                            <option value="Accepted" selected="@(item.Status == FeedbackStatus.Accepted ? "selected" : null)">Решено (Принято)</option>
                                            <option value="Rejected" selected="@(item.Status == FeedbackStatus.Rejected ? "selected" : null)">Отклонено</option>
                                        </select>
                                    </div>

                                    @* Скрываем кнопку отправки от Менеджера *@
                                    @if (User.IsInRole("Администратор"))
                                    {
                                        <div class="col-md-8 text-md-end mt-3 mt-md-0">
                                            <button type="submit" class="btn btn-primary px-4 py-2 fw-bold rounded-pill shadow-sm">
                                                <i class="bi bi-send me-1"></i> Сохранить и ответить
                                            </button>
                                        </div>
                                    }
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@* ПОДКЛЮЧАЕМ СКРИПТЫ ВАЛИДАЦИИ *@
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .fw-800 {
        font-weight: 800;
    }

    .ls-1 {
        letter-spacing: 1px;
    }

    .text-purple {
        color: #8b5cf6;
    }

    /* ДОБАВЛЕНО: Красная рамка для полей с ошибкой */
    .input-validation-error {
        border-color: #dc3545 !important;
        background-color: #fff8f8;
    }
</style>