@model Apex7.Data.Entities.News

<div class="container py-5 mt-4" style="max-width: 850px;">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="NewsList" class="text-muted">Список новостей</a></li>
            <li class="breadcrumb-item active">Редактирование</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-lg rounded-4 p-4">
        <h2 class="fw-800 text-uppercase mb-4">Редактировать <span class="text-primary">Экспедицию</span></h2>

        <form asp-action="EditNews" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="NewsID" />
            <input type="hidden" asp-for="CreatedAt" />

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label class="form-label fw-bold text-muted small">ЗАГОЛОВОК</label>
                <input asp-for="Title" class="form-control rounded-3 py-2 border-2" maxlength="100" />
                <span asp-validation-for="Title" class="text-danger small fw-bold"></span>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold text-muted small">ГЛАВНОЕ ФОТО</label>
                    @if (!string.IsNullOrEmpty(Model.ImageURL))
                    {
                        <div class="mb-2">
                            <img src="@Model.ImageURL" class="rounded-3 shadow-sm mb-2" style="width: 100%; height: 150px; object-fit: cover;" />
                            <p class="small text-muted">Текущее фото</p>
                        </div>
                    }
                    <input type="file" name="image1" class="form-control rounded-3 border-2" accept="image/*" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold text-muted small">ДОПОЛНИТЕЛЬНОЕ ФОТО</label>
                    @if (!string.IsNullOrEmpty(Model.ImageURL2))
                    {
                        <div class="mb-2">
                            <img src="@Model.ImageURL2" class="rounded-3 shadow-sm mb-2" style="width: 100%; height: 150px; object-fit: cover;" />
                            <p class="small text-muted">Текущее фото</p>
                        </div>
                    }
                    <input type="file" name="image2" class="form-control rounded-3 border-2" accept="image/*" />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold text-muted small">ОПИСАНИЕ СОБЫТИЯ</label>
                <textarea asp-for="Content" class="form-control rounded-3 border-2" rows="5" maxlength="350"></textarea>
                <span asp-validation-for="Content" class="text-danger small fw-bold"></span>
                <div class="text-muted small text-end">Осталось символов: <span id="charCount">350</span></div>
            </div>

            <div class="form-check form-switch mb-4">
                <input class="form-check-input" type="checkbox" asp-for="IsArchived" id="archiveSwitch">
                <label class="form-check-label fw-bold" for="archiveSwitch">Архивировать новость (скрыть с главной)</label>
            </div>

            <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                <a asp-action="NewsList" class="btn btn-light rounded-pill px-4 border">Отмена</a>
                <button type="submit" class="btn btn-primary rounded-pill px-5 shadow-sm hover-lift fw-bold">
                    Сохранить изменения
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Небольшой скрипт для счетчика символов (для удобства админа)
        const textarea = document.querySelector('textarea[asp-for="Content"]');
        const counter = document.getElementById('charCount');

        if (textarea) {
            textarea.addEventListener('input', () => {
                const remaining = 350 - textarea.value.length;
                counter.textContent = remaining;
                counter.className = remaining < 20 ? "text-danger fw-bold" : "text-muted";
            });
            // Инициализация при загрузке
            counter.textContent = 350 - textarea.value.length;
        }
    </script>
}

<style>
    .fw-800 {
        font-weight: 800;
    }

    .hover-lift {
        transition: 0.2s;
    }

        .hover-lift:hover {
            transform: translateY(-2px);
        }
    /* Подсветка полей с ошибками будет работать из твоего validation.css */
</style>